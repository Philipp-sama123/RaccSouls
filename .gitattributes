# Normalize text files
* text=auto

# Unity YAML assets should stay text for useful diffs and merges.
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.prefab text eol=lf
*.renderTexture text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf
*.shadervariants text eol=lf
*.terrainlayer text eol=lf
*.unity text eol=lf
*.uss text eol=lf
*.uxml text eol=lf

# Code and config
*.cs text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Git LFS for large/binary Unity assets
